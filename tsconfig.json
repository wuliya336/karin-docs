{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "**/*.ts",
    "node_modules/node-karin/**/*.ts"
  ]
}