{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "baseUrl": ".",
    "paths": {
      "vue": [
        "node_modules/vue/dist/vue"
      ],
      "vitepress": [
        "node_modules/vitepress/types/index"
      ]
    },
    "strict": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "docs/**/*.ts",
    "docs/**/*.d.ts",
    "docs/**/*.vue",
    "env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ],
}